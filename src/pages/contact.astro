---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import Section from '@components/ui/Section.astro';
import Button from '@components/ui/Button.astro';
import { site } from '@data/site';
import { founders } from '@data/founders';

const intents = [
  {
    key: 'land',
    label: 'I have land',
    text: 'A plot or parcel and the question of what can be built — and financed — on it.',
    who: 'Starts with Esad · feasibility',
  },
  {
    key: 'structure',
    label: 'I have a project to structure',
    text: 'An idea or early scheme that needs to become a buildable, fundable project.',
    who: 'Esad + Dionis · the full chain',
  },
  {
    key: 'market',
    label: 'I’m preparing to go to market',
    text: 'A project that needs pricing, a dossier and an off-plan pre-sale to clear the quota.',
    who: 'Starts with Dionis · commercialization',
  },
];
---

<BaseLayout
  title="Contact"
  description="Talk to ZweiFach about your development — whether you have land, a project to structure, or a building to bring to market."
>
  <PageHero
    kicker="Contact"
    title="Start the chain."
    intro="Tell us where you are. The more concrete the project, the more useful our first answer will be."
  />

  <Section tone="paper">
    <div class="grid gap-16 lg:grid-cols-[1.1fr_0.9fr] lg:gap-24">
      <!-- Form -->
      <div data-reveal>
        <h2 class="font-serif text-3xl">Send us a note</h2>
        <form id="contact-form" class="mt-8 grid gap-6" novalidate data-email={site.contact.email}>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <label for="name" class="kicker kicker--bare">Name</label>
              <input id="name" name="name" type="text" required autocomplete="name"
                class="mt-2 w-full rounded-lg border border-ink/15 bg-paper px-4 py-3 text-ink transition-colors placeholder:text-taupe focus:border-ink focus:outline-none" />
            </div>
            <div>
              <label for="email" class="kicker kicker--bare">Email</label>
              <input id="email" name="email" type="email" required autocomplete="email"
                class="mt-2 w-full rounded-lg border border-ink/15 bg-paper px-4 py-3 text-ink transition-colors placeholder:text-taupe focus:border-ink focus:outline-none" />
            </div>
          </div>

          <div>
            <label for="company" class="kicker kicker--bare">Company / role <span class="text-taupe">(optional)</span></label>
            <input id="company" name="company" type="text"
              class="mt-2 w-full rounded-lg border border-ink/15 bg-paper px-4 py-3 text-ink transition-colors placeholder:text-taupe focus:border-ink focus:outline-none" />
          </div>

          <div>
            <label for="intent" class="kicker kicker--bare">Where are you?</label>
            <select id="intent" name="intent"
              class="mt-2 w-full rounded-lg border border-ink/15 bg-paper px-4 py-3 text-ink transition-colors focus:border-ink focus:outline-none">
              <option value="I have land / a site">I have land / a site</option>
              <option value="I have a project to structure">I have a project to structure</option>
              <option value="I’m preparing to go to market">I’m preparing to go to market</option>
              <option value="Something else">Something else</option>
            </select>
          </div>

          <div>
            <label for="message" class="kicker kicker--bare">Project</label>
            <textarea id="message" name="message" rows="5" required
              placeholder="Location, type, where you are on the chain…"
              class="mt-2 w-full rounded-lg border border-ink/15 bg-paper px-4 py-3 text-ink transition-colors placeholder:text-taupe focus:border-ink focus:outline-none"></textarea>
          </div>

          <div class="flex flex-wrap items-center gap-4">
            <Button type="submit" variant="primary">Send</Button>
            <p id="form-note" class="font-mono text-xs text-taupe" role="status"></p>
          </div>
          <p class="font-mono text-[0.65rem] leading-relaxed text-taupe">
            Opens your email client. To connect a backend form service, set the
            endpoint in <span class="text-ink/60">src/pages/contact.astro</span>.
          </p>
        </form>
      </div>

      <!-- Details -->
      <div data-reveal>
        <h2 class="font-serif text-3xl">Direct</h2>
        <dl class="mt-8 space-y-6">
          <div class="border-t border-ink/15 pt-4">
            <dt class="kicker kicker--bare">General</dt>
            <dd class="mt-2">
              <a href={`mailto:${site.contact.email}`} class="link-underline">{site.contact.email}</a>
            </dd>
            <dd class="mt-1 font-mono text-sm text-taupe">{site.contact.phone}</dd>
          </div>
          {
            founders.map((f) => (
              <div class="border-t border-ink/15 pt-4">
                <dt class="kicker kicker--bare">{f.discipline}</dt>
                <dd class="mt-2 font-sans">{f.name}</dd>
                <dd class="mt-1">
                  <a href={`mailto:${f.email}`} class="link-underline text-sm">{f.email}</a>
                </dd>
              </div>
            ))
          }
          <div class="border-t border-ink/15 pt-4">
            <dt class="kicker kicker--bare">Studio</dt>
            <dd class="mt-2 text-sm leading-relaxed text-ink/70">
              {site.location.city}, {site.location.canton}<br />
              {site.location.country}
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </Section>

  <!-- Intent quick-paths -->
  <Section tone="paper-2">
    <div class="grid gap-6 md:grid-cols-3">
      {
        intents.map((i, idx) => (
          <div
            data-reveal
            style={`--reveal-delay:${idx * 80}ms`}
            class="rounded-2xl border border-ink/10 bg-paper p-7"
          >
            <p class="font-mono text-[0.62rem] uppercase tracking-wider text-clay">{i.who}</p>
            <h3 class="mt-3 font-serif text-2xl">{i.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/65">{i.text}</p>
          </div>
        ))
      }
    </div>
  </Section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const note = document.getElementById('form-note');
  const select = document.getElementById('intent') as HTMLSelectElement | null;
  const email = form?.dataset.email ?? '';

  // Preselect from ?intent=
  const map: Record<string, string> = {
    land: 'I have land / a site',
    structure: 'I have a project to structure',
    market: 'I’m preparing to go to market',
  };
  const param = new URLSearchParams(window.location.search).get('intent');
  if (param && map[param] && select) select.value = map[param];

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = (data.get('name') || '').toString().trim();
    const mail = (data.get('email') || '').toString().trim();
    const message = (data.get('message') || '').toString().trim();
    if (!name || !mail || !message) {
      if (note) note.textContent = 'Please add your name, email and a short note.';
      return;
    }
    const subject = `Project enquiry — ${data.get('intent')}`;
    const body =
      `Name: ${name}\nEmail: ${mail}\nCompany/role: ${data.get('company') || '—'}\n` +
      `Where: ${data.get('intent')}\n\n${message}`;
    window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    if (note) note.textContent = 'Opening your email client…';
  });
</script>
