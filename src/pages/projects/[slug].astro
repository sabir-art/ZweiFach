---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import SpecList from '@components/ui/SpecList.astro';
import LotTable from '@components/ui/LotTable.astro';
import Figure from '@components/ui/Figure.astro';
import ContactCta from '@components/sections/ContactCta.astro';
import { resolveAsset, statusLabel, expertiseLabel } from '@lib/projects';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const hero = resolveAsset(data.heroAsset);
const gallery = data.gallery.map((k) => resolveAsset(k)).filter(Boolean);
---

<BaseLayout
  title={data.title}
  description={data.seoDescription ?? data.summary}
  type="article"
  image={hero?.url}
>
  <article>
    <!-- Project hero -->
    <section class="bg-paper pt-32 md:pt-40">
      <div class="shell">
        <a href="/projects/" class="link-underline font-mono text-xs uppercase tracking-wider text-taupe">
          ← Projects
        </a>
        <div class="mt-8 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[0.7rem] uppercase tracking-wider text-taupe">
          <span class="rounded-full bg-ink px-3 py-1 text-paper">{statusLabel[data.status]}</span>
          <span>{data.location}</span>
          <span aria-hidden="true">·</span>
          <span>{data.type}</span>
          <span aria-hidden="true">·</span>
          <span>{expertiseLabel[data.expertise]}</span>
        </div>
        <h1
          class="mt-6 font-sans text-[clamp(2.6rem,1rem+6vw,5.5rem)] font-bold leading-[0.98] tracking-[-0.03em]"
          data-reveal
        >
          {data.title}
        </h1>
        <p class="mt-6 max-w-2xl text-xl leading-relaxed text-ink/70" data-reveal>{data.summary}</p>
      </div>

      <div class="shell mt-10">
        <Figure asset={hero} aspect="16 / 9" eager class="rounded-2xl">
          {!hero && (
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="font-serif text-4xl text-ink/30">{data.title}</span>
            </div>
          )}
        </Figure>
      </div>
    </section>

    <!-- Facts + the chain -->
    <Section tone="paper">
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-20">
        <div data-reveal>
          <p class="kicker">Project facts</p>
          <SpecList items={data.facts} class="mt-4" />
          {
            data.isPlaceholder && (
              <p class="mt-6 font-mono text-[0.68rem] uppercase tracking-wider text-taupe">
                Illustrative placeholder — to be replaced with real data.
              </p>
            )
          }
        </div>

        <div data-reveal>
          <p class="kicker">The chain — who did what</p>
          <ul class="mt-5 space-y-5">
            {
              data.roles.map((r) => (
                <li class="border-t border-ink/12 pt-4">
                  <p class="font-sans font-semibold">{r.who}</p>
                  <p class="mt-1 text-sm leading-relaxed text-ink/65">{r.what}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </Section>

    <!-- Narrative -->
    <Section tone="paper-2">
      <div class="prose-zf mx-auto max-w-2xl" data-reveal>
        <Content />
      </div>
    </Section>

    <!-- Lots -->
    {
      data.lots.length > 0 && (
        <Section tone="paper">
          <div class="mx-auto max-w-3xl">
            <LotTable lots={data.lots} />
            {data.outcome && (
              <div class="mt-8 rounded-2xl bg-graphite p-7 text-paper md:p-9" data-reveal>
                <p class="kicker !text-paper/55">Outcome</p>
                <p class="mt-3 font-serif text-2xl leading-snug md:text-3xl">{data.outcome}</p>
              </div>
            )}
          </div>
        </Section>
      )
    }

    <!-- Gallery -->
    {
      gallery.length > 0 && (
        <Section tone={data.lots.length > 0 ? 'paper-2' : 'paper'}>
          <SectionHeading kicker="Gallery" title="Inside the project." />
          <div class="mt-12 grid gap-6 sm:grid-cols-2">
            {gallery.map((g) => (
              <Figure asset={g!} aspect="3 / 2" class="rounded-xl" />
            ))}
          </div>
        </Section>
      )
    }
  </article>

  <ContactCta
    heading="Discuss a project like this."
    text="If this is the kind of development you’re planning, let’s talk about where you are on the chain."
  />
</BaseLayout>
