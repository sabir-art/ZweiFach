---
import BaseLayout from '@layouts/BaseLayout.astro';
import MosaicHero from '@components/sections/MosaicHero.astro';
import Marquee from '@components/sections/Marquee.astro';
import Section from '@components/ui/Section.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Vision from '@components/sections/Vision.astro';
import CapabilitySwitcher from '@components/sections/CapabilitySwitcher.astro';
import ZoomBand from '@components/sections/ZoomBand.astro';
import ThroughLine from '@components/sections/ThroughLine.astro';
import StatBand from '@components/sections/StatBand.astro';
import ProjectsRail from '@components/sections/ProjectsRail.astro';
import PartnersStrip from '@components/sections/PartnersStrip.astro';
import ContactCta from '@components/sections/ContactCta.astro';
import Button from '@components/ui/Button.astro';

import { assets } from '@data/assets';
---

<BaseLayout headerVariant="over-hero">
  <!-- Hero gallery -->
  <MosaicHero />

  <Marquee />

  <!-- (01) What we believe — organic field + manifesto -->
  <Vision />

  <!-- (02) What we do — interactive capability switcher -->
  <Section tone="paper">
    <div class="flex items-center justify-between">
      <p class="kicker" data-reveal>What we do</p>
      <span class="corner-label text-taupe" data-reveal>(02)</span>
    </div>
    <h2
      class="mt-8 max-w-3xl font-serif text-[clamp(2.2rem,1rem+4vw,4.5rem)] leading-[1.02]"
      data-reveal
    >
      Two specialists. Four moves. One chain.
    </h2>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink/65" data-reveal>
      An architect and a commercialization lead, holding every link from a raw
      plot to the final signature.
    </p>
    <div class="mt-14 md:mt-20">
      <CapabilitySwitcher />
    </div>
  </Section>

  <!-- Zoom band — the gate -->
  <ZoomBand
    asset={assets.caseUferpark}
    kicker="The gate"
    title="Plans don’t unlock financing. Proven demand does."
  />

  <!-- (03) The through-line — cinematic value chain -->
  <ThroughLine />

  <!-- (04) Selected work -->
  <section class="bg-graphite py-20 text-paper md:py-28 lg:py-32">
    <div class="shell">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <div class="flex items-center gap-4">
            <p class="kicker !text-paper/55" data-reveal>Selected work</p>
            <span class="corner-label text-paper/40" data-reveal>(04)</span>
          </div>
          <h2 class="mt-5 font-serif text-4xl leading-[1.05] md:text-5xl" data-reveal>
            Proof, not promises.
          </h2>
        </div>
        <div class="hidden items-center gap-4 md:flex" data-reveal>
          <span class="corner-label text-paper/40">Drag</span>
          <Button href="/projects/" variant="inverse">All projects</Button>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <ProjectsRail />
    </div>

    <div class="shell mt-8 flex items-center justify-between">
      <p class="corner-label text-paper/40" data-reveal>
        Placeholder case studies — to be replaced.
      </p>
      <div class="md:hidden" data-reveal>
        <Button href="/projects/" variant="inverse">All projects</Button>
      </div>
    </div>
  </section>

  <!-- By the numbers -->
  <section class="bg-graphite py-20 text-paper md:py-28">
    <div class="shell">
      <h2 class="max-w-3xl font-serif text-4xl leading-[1.05] md:text-5xl" data-reveal>
        Small by design. Precise by necessity.
      </h2>
      <div class="mt-14">
        <StatBand tone="graphite" />
      </div>
    </div>
  </section>

  <!-- Ecosystem -->
  <Section tone="paper-2">
    <SectionHeading
      kicker="Ecosystem"
      title="Two of us. A wider chain."
      intro="We design and we sell. Specialist partners extend the chain — without diluting the duo."
    />
    <div class="mt-12">
      <PartnersStrip />
    </div>
  </Section>

  <ContactCta />
</BaseLayout>
