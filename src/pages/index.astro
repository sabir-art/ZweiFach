---
import BaseLayout from '@layouts/BaseLayout.astro';
import MosaicHero from '@components/sections/MosaicHero.astro';
import Marquee from '@components/sections/Marquee.astro';
import Section from '@components/ui/Section.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import ThroughLine from '@components/sections/ThroughLine.astro';
import Expertise from '@components/sections/Expertise.astro';
import StatBand from '@components/sections/StatBand.astro';
import ProjectsRail from '@components/sections/ProjectsRail.astro';
import PartnersStrip from '@components/sections/PartnersStrip.astro';
import ContactCta from '@components/sections/ContactCta.astro';
import Button from '@components/ui/Button.astro';
import Figure from '@components/ui/Figure.astro';

import { assets } from '@data/assets';
---

<BaseLayout headerVariant="over-hero">
  <MosaicHero />

  <Marquee />

  <!-- (01) The tension -->
  <Section tone="paper-2">
    <div class="flex items-center justify-between">
      <p class="kicker" data-reveal>The tension</p>
      <span class="corner-label text-taupe" data-reveal>(01)</span>
    </div>
    <div class="mt-10 grid gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-7">
        <h2 class="font-serif text-[clamp(2.2rem,1rem+5vw,5rem)] leading-[1.02]" data-reveal>
          A beautiful project isn’t enough. It has to be
          <span class="display-italic text-clay">financeable.</span>
        </h2>
        <div class="mt-9 grid max-w-2xl gap-5 text-lg leading-relaxed text-ink/70">
          <p data-reveal style="--reveal-delay:80ms">
            Banks release construction credit only once a quota of apartments is
            pre-sold — often before ground is broken. Plans alone don’t unlock
            financing; proven demand does.
          </p>
          <p data-reveal style="--reveal-delay:160ms">
            That’s the link that breaks on most developments: a strong design with
            no one to pre-sell it, or a sales push with nothing buildable behind
            it. ZweiFach holds both ends of the chain.
          </p>
        </div>
      </div>
      <div class="lg:col-span-5">
        <Figure asset={assets.archModel} aspect="4 / 5" class="media-reveal rounded-2xl" data-reveal data-parallax="0.08" />
        <p class="corner-label mt-4 text-taupe" data-reveal>Feasibility · plans · model</p>
      </div>
    </div>
  </Section>

  <!-- (02) The through-line — cinematic value chain -->
  <ThroughLine />

  <!-- (03) Selected work -->
  <section class="bg-graphite py-20 text-paper md:py-28 lg:py-32">
    <div class="shell">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <div class="flex items-center gap-4">
            <p class="kicker !text-paper/55" data-reveal>Selected work</p>
            <span class="corner-label text-paper/40" data-reveal>(03)</span>
          </div>
          <h2 class="mt-5 font-serif text-4xl leading-[1.05] md:text-5xl" data-reveal>
            Proof, not promises.
          </h2>
        </div>
        <div class="hidden items-center gap-4 md:flex" data-reveal>
          <span class="corner-label text-paper/40">Drag</span>
          <Button href="/projects/" variant="inverse">All projects</Button>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <ProjectsRail />
    </div>

    <div class="shell mt-8 flex items-center justify-between">
      <p class="corner-label text-paper/40" data-reveal>
        Placeholder case studies — to be replaced.
      </p>
      <div class="md:hidden" data-reveal>
        <Button href="/projects/" variant="inverse">All projects</Button>
      </div>
    </div>
  </section>

  <!-- (04) The duo -->
  <Section tone="paper-2">
    <div class="flex items-center justify-between">
      <p class="kicker" data-reveal>The duo</p>
      <span class="corner-label text-taupe" data-reveal>(04)</span>
    </div>
    <h2 class="mt-8 max-w-3xl font-serif text-[clamp(2.2rem,1rem+4vw,4.5rem)] leading-[1.02]" data-reveal>
      Two specialists, one chain.
    </h2>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink/65" data-reveal>
      ZweiFach is deliberately two people — an architect and a commercialization
      lead — so design and sales are never handed off across a gap.
    </p>
    <div class="mt-16">
      <Expertise />
    </div>
  </Section>

  <!-- By the numbers -->
  <section class="bg-graphite py-20 text-paper md:py-28">
    <div class="shell">
      <h2 class="max-w-3xl font-serif text-4xl leading-[1.05] md:text-5xl" data-reveal>
        Small by design. Precise by necessity.
      </h2>
      <div class="mt-14">
        <StatBand tone="graphite" />
      </div>
    </div>
  </section>

  <!-- Ecosystem -->
  <Section tone="paper-2">
    <SectionHeading
      kicker="Ecosystem"
      title="Two of us. A wider chain."
      intro="We design and we sell. Specialist partners extend the chain — without diluting the duo."
    />
    <div class="mt-12">
      <PartnersStrip />
    </div>
  </Section>

  <ContactCta />
</BaseLayout>
