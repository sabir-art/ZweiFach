---
/** Wordmark with the two-strand mark — blueprint + clay, the duo distilled. */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a
  href="/"
  class:list={['group inline-flex items-center gap-2.5', className]}
  aria-label="ZweiFach — home"
>
  <span class="flex items-end gap-[3.5px]" aria-hidden="true">
    <span
      class="block h-[1.15rem] w-[3px] rounded-[2px] bg-blueprint transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-[3px]"
    ></span>
    <span
      class="block h-[1.15rem] w-[3px] rounded-[2px] bg-clay transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:translate-y-[3px]"
    ></span>
  </span>
  <span class="font-sans text-[1.15rem] font-bold leading-none tracking-[-0.02em]">ZweiFach</span>
</a>
