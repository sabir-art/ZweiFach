---
import Logo from './Logo.astro';
import { footerNav } from '@data/nav';
import { site } from '@data/site';

const year = 2026;
---

<footer class="relative bg-graphite text-paper">
  <!-- The two strands, one last time -->
  <div class="h-[2px] w-full bg-gradient-to-r from-blueprint via-blueprint to-clay" aria-hidden="true"></div>

  <div class="shell grid gap-12 py-16 md:grid-cols-12 md:py-20">
    <div class="md:col-span-5">
      <Logo />
      <p class="mt-5 max-w-xs font-serif text-xl leading-snug text-paper/90">
        {site.tagline}
      </p>
      <p class="mt-6 max-w-sm text-sm leading-relaxed text-paper/55">
        {site.shortPitch}
      </p>
      <div class="mt-7 space-y-1.5 font-mono text-[0.8rem] text-paper/70">
        <a href={`mailto:${site.contact.email}`} class="link-underline block w-fit">{site.contact.email}</a>
        <p>{site.location.city} · {site.location.canton} · {site.location.country}</p>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-8 md:col-span-7 md:grid-cols-3">
      {
        footerNav.map((col) => (
          <nav aria-label={col.heading}>
            <h2 class="kicker kicker--bare !text-paper/45">{col.heading}</h2>
            <ul class="mt-4 space-y-3">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="link-underline text-sm text-paper/80 hover:text-paper"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>
  </div>

  <div class="shell flex flex-col gap-3 border-t border-paper/10 py-7 text-xs text-paper/45 sm:flex-row sm:items-center sm:justify-between">
    <p>© {year} {site.legalName}. All rights reserved.</p>
    <p class="font-mono">
      Architecture &amp; commercialization, under one roof.
    </p>
  </div>
</footer>
