---
/**
 * Button / CTA. Renders an <a> when `href` is set, otherwise a <button>.
 * variants: primary (ink), inverse (paper, for dark sections), line (text + arrow).
 * Premium hover: a colour fill wipes up behind the label.
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'inverse' | 'line';
  type?: 'button' | 'submit';
  class?: string;
  arrow?: boolean;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  type = 'button',
  class: className = '',
  arrow = true,
  ...rest
} = Astro.props;

const base =
  'group/btn relative inline-flex items-center gap-2 overflow-hidden font-sans text-[0.92rem] font-medium transition-colors duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] focus-visible:outline-2';

// Solid variants get a fill that rises on hover. `fill` is the rising colour.
const variants: Record<string, { box: string; fill: string }> = {
  primary: {
    box: 'rounded-full bg-ink px-5 py-2.5 text-paper hover:text-paper',
    fill: 'bg-clay',
  },
  inverse: {
    box: 'rounded-full bg-paper px-5 py-2.5 text-ink hover:text-paper',
    fill: 'bg-ink',
  },
  line: { box: 'pb-1 text-ink hover:text-clay', fill: '' },
};

const v = variants[variant];
const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  type={href ? undefined : type}
  class:list={[base, v.box, className]}
  data-cursor
  {...rest}
>
  {
    v.fill && (
      <span
        aria-hidden="true"
        class:list={[
          'pointer-events-none absolute inset-0 translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover/btn:translate-y-0',
          v.fill,
        ]}
      />
    )
  }
  <span class:list={['relative z-10', variant === 'line' ? 'link-underline' : '']}><slot /></span>
  {
    arrow && (
      <span
        aria-hidden="true"
        class="relative z-10 transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover/btn:translate-x-1"
      >
        →
      </span>
    )
  }
</Tag>
