---
/**
 * Button / CTA. Renders an <a> when `href` is set, otherwise a <button>.
 * variants: primary (ink), inverse (paper, for dark sections), line (text + arrow).
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'inverse' | 'line';
  type?: 'button' | 'submit';
  class?: string;
  arrow?: boolean;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  type = 'button',
  class: className = '',
  arrow = true,
  ...rest
} = Astro.props;

const base =
  'group/btn inline-flex items-center gap-2 font-sans text-[0.92rem] font-medium transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] focus-visible:outline-2';

const variants: Record<string, string> = {
  primary:
    'rounded-full bg-ink px-5 py-2.5 text-paper hover:bg-graphite hover:shadow-[0_8px_30px_-12px_rgba(22,24,26,0.5)]',
  inverse: 'rounded-full bg-paper px-5 py-2.5 text-ink hover:bg-white',
  line: 'pb-1 text-ink hover:text-clay',
};

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  type={href ? undefined : type}
  class:list={[base, variants[variant], className]}
  {...rest}
>
  <span class={variant === 'line' ? 'link-underline' : ''}><slot /></span>
  {
    arrow && (
      <span
        aria-hidden="true"
        class="transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover/btn:translate-x-1"
      >
        →
      </span>
    )
  }
</Tag>
