---
import type { Project } from '@lib/projects';
import { statusLabel, expertiseLabel, resolveAsset } from '@lib/projects';
import Figure from '@components/ui/Figure.astro';

interface Props {
  project: Project;
  class?: string;
  eager?: boolean;
}
const { project, class: className = '', eager = false } = Astro.props;
const { data } = project;
const asset = resolveAsset(data.heroAsset);
const href = `/projects/${project.id}/`;
---

<a href={href} class:list={['group block', className]}>
  <Figure
    asset={asset}
    aspect="3 / 2"
    eager={eager}
    class="rounded-xl"
    imgClass="transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
  >
    <span
      class="absolute left-4 top-4 z-10 rounded-full bg-paper/90 px-3 py-1 font-mono text-[0.62rem] uppercase tracking-wider text-ink backdrop-blur"
    >
      {statusLabel[data.status]}
    </span>
    {
      !asset && (
        <div class="absolute inset-0 flex items-center justify-center p-6 text-center">
          <span class="font-serif text-3xl text-ink/30">{data.title}</span>
        </div>
      )
    }
  </Figure>

  <div class="mt-4 flex items-baseline justify-between gap-4">
    <h3 class="font-serif text-2xl leading-tight">{data.title}</h3>
    <span class="shrink-0 font-mono text-xs text-taupe">{data.year}</span>
  </div>
  <p class="mt-1 font-mono text-[0.7rem] uppercase tracking-wider text-taupe">
    {data.location} · {expertiseLabel[data.expertise]}
  </p>
  <p class="mt-2.5 max-w-md text-sm leading-relaxed text-ink/65">{data.summary}</p>
  <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium">
    <span class="link-underline">View case study</span>
    <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
  </span>
</a>
