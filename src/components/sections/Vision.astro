---
/**
 * Vision — the atmospheric "belief" beat. ZweiFach's answer to the Springs
 * Wellness section: an organic, slowly-drifting gradient field (pure CSS —
 * the markdown's accepted lightweight alternative to WebGL) behind a manifesto
 * that reveals word by word. This is the emotional respiration after the hero.
 */
const beliefs = [
  {
    k: 'Design is the first lever of value',
    t: 'A plan is not decoration. It is the instrument that decides what a site is worth — and whether a bank will fund it.',
  },
  {
    k: 'Demand is proven, not assumed',
    t: 'Credit follows pre-sales. So the selling starts on paper, long before the first wall — that is the gate, not the finish line.',
  },
  {
    k: 'One hand holds both ends',
    t: 'The people who design the building are the people who get it financed and sold. No wall, no hand-off, no lost link.',
  },
];
---

<section class="vision relative overflow-hidden bg-ink py-28 text-paper md:py-40">
  <div class="vision-field" aria-hidden="true">
    <span class="vision-blob vision-blob--1"></span>
    <span class="vision-blob vision-blob--2"></span>
    <span class="vision-blob vision-blob--3"></span>
  </div>

  <div class="shell relative z-10">
    <div class="flex items-center justify-between">
      <p class="kicker !text-paper/55" data-reveal>What we believe</p>
      <span class="corner-label text-paper/35" data-reveal>(01)</span>
    </div>

    <h2
      class="mt-9 max-w-5xl font-serif text-[clamp(2rem,1rem+4.1vw,5rem)] leading-[1.07]"
      data-split
    >
      A beautiful project isn’t enough. It has to be financeable — which means it has to be sold before it’s built.
    </h2>

    <div class="mt-16 grid gap-10 border-t border-paper/15 pt-10 md:grid-cols-3 md:gap-12">
      {
        beliefs.map((b, i) => (
          <div data-reveal style={`--reveal-delay:${i * 110}ms`}>
            <p class="font-sans text-lg font-semibold leading-snug">{b.k}</p>
            <p class="mt-3 leading-relaxed text-paper/65">{b.t}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .vision-field {
    position: absolute;
    inset: -25%;
    z-index: 0;
    filter: blur(80px);
    opacity: 0.55;
    pointer-events: none;
  }
  .vision-blob {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
    will-change: transform;
  }
  .vision-blob--1 {
    width: 60vw;
    height: 60vw;
    left: -8%;
    top: -12%;
    background: radial-gradient(circle, var(--color-blueprint-soft), transparent 64%);
    animation: vision-drift-1 26s ease-in-out infinite;
  }
  .vision-blob--2 {
    width: 52vw;
    height: 52vw;
    right: -6%;
    top: 8%;
    background: radial-gradient(circle, var(--color-clay), transparent 66%);
    animation: vision-drift-2 32s ease-in-out infinite;
  }
  .vision-blob--3 {
    width: 46vw;
    height: 46vw;
    left: 28%;
    bottom: -22%;
    background: radial-gradient(circle, var(--color-blueprint), transparent 68%);
    animation: vision-drift-3 29s ease-in-out infinite;
  }
  @keyframes vision-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(10vw, 7vh) scale(1.18); }
  }
  @keyframes vision-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1.05); }
    50% { transform: translate(-9vw, 9vh) scale(0.92); }
  }
  @keyframes vision-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(6vw, -8vh) scale(1.2); }
  }
  @media (prefers-reduced-motion: reduce) {
    .vision-blob {
      animation: none;
    }
  }
</style>
