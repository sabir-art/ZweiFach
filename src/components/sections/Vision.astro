---
/**
 * Vision — the "what we believe" beat, on a light ground. Instead of the dark
 * organic field, a warm clay halo drifts behind a faint blueprint plan-grid +
 * pixel texture (architecture, not wellness). The manifesto reveals word by
 * word; the three beliefs rise after it.
 */
const beliefs = [
  {
    k: 'Design is the first lever of value',
    t: 'A plan is not decoration. It is the instrument that decides what a site is worth — and whether a bank will fund it.',
  },
  {
    k: 'Demand is proven, not assumed',
    t: 'Credit follows pre-sales. So the selling starts on paper, long before the first wall — that is the gate, not the finish line.',
  },
  {
    k: 'One hand holds both ends',
    t: 'The people who design the building are the people who get it financed and sold. No wall, no hand-off, no lost link.',
  },
];
---

<section class="vision relative overflow-hidden bg-paper py-28 text-ink md:py-40">
  <div class="vision-grid" aria-hidden="true"></div>
  <div class="vision-dots" aria-hidden="true"></div>
  <div class="vision-halo" aria-hidden="true"></div>

  <div class="shell relative z-10">
    <div class="flex items-center justify-between">
      <p class="kicker" data-reveal>What we believe</p>
      <span class="corner-label text-taupe" data-reveal>(01)</span>
    </div>

    <h2
      class="mt-9 max-w-5xl font-serif text-[clamp(2rem,1rem+4.1vw,5rem)] leading-[1.07]"
      data-split
    >
      A beautiful project isn’t enough. It has to be financeable — which means it has to be sold before it’s built.
    </h2>

    <div class="mt-16 grid gap-10 border-t border-ink/15 pt-10 md:grid-cols-3 md:gap-12">
      {
        beliefs.map((b, i) => (
          <div
            data-reveal
            data-reveal-dir={i === 0 ? 'left' : i === 2 ? 'right' : undefined}
            style={`--reveal-delay:${i * 110}ms`}
          >
            <p class="font-sans text-lg font-semibold leading-snug">{b.k}</p>
            <p class="mt-3 leading-relaxed text-ink/65">{b.t}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Blueprint plan grid, faded from the upper-left */
  .vision-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--color-blueprint) 12%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--color-blueprint) 12%, transparent) 1px, transparent 1px);
    background-size: 40px 40px;
    -webkit-mask: radial-gradient(120% 120% at 12% 0%, #000, transparent 70%);
    mask: radial-gradient(120% 120% at 12% 0%, #000, transparent 70%);
  }
  /* Fine pixel/dot texture, like a plot grid */
  .vision-dots {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(
      color-mix(in srgb, var(--color-blueprint) 16%, transparent) 1px,
      transparent 1.4px
    );
    background-size: 13px 13px;
    -webkit-mask: radial-gradient(80% 80% at 85% 100%, #000, transparent 72%);
    mask: radial-gradient(80% 80% at 85% 100%, #000, transparent 72%);
    opacity: 0.7;
  }
  /* Warm clay halo, slowly drifting */
  .vision-halo {
    position: absolute;
    z-index: 0;
    top: -20%;
    right: -10%;
    width: 70vw;
    height: 70vw;
    max-width: 920px;
    max-height: 920px;
    pointer-events: none;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-clay) 42%, transparent),
      transparent 62%
    );
    filter: blur(40px);
    opacity: 0.5;
    animation: vision-halo-drift 26s ease-in-out infinite alternate;
  }
  @keyframes vision-halo-drift {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(-8vw, 6vh) scale(1.15); }
  }
  @media (prefers-reduced-motion: reduce) {
    .vision-halo { animation: none; }
  }
</style>
