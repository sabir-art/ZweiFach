---
/**
 * MosaicHero — the "wow" opener, in the Springs register (adapted, not copied).
 *
 * A full-viewport wall of image tiles arranged in columns, the whole grid
 * rotated ~20° and drifting slowly — neighbouring columns travel in opposite
 * directions, so the mosaic feels alive even before you scroll. A blueprint
 * multiply-tint + ink gradient unifies the warm renders into one cinematic,
 * on-brand wash; the editorial headline and CTAs sit on top. On scroll the
 * whole grid takes a gentle parallax (data-parallax). Drift + parallax are
 * pure GPU transforms and switch off under prefers-reduced-motion.
 */
import { assets, assetSrc } from '@data/assets';
import { site } from '@data/site';
import Button from '@components/ui/Button.astro';

const pool = [
  assets.caseAarefeld,
  assets.interiorLiving,
  assets.caseHoehenweg,
  assets.archModel,
  assets.caseUferpark,
  assets.interiorKitchen,
  assets.caseLindenpark,
  assets.studioWork,
  assets.caseWerkhof,
  assets.homeHero,
];

const COLS = 5;
const PER = 5;

// Prefer the optimized WebP sibling for locally-hosted assets.
const webpOf = (a: (typeof pool)[number]) => {
  const u = assetSrc(a);
  return u.startsWith('/') && /\.jpe?g$/i.test(u) ? u.replace(/\.jpe?g$/i, '.webp') : u;
};

// One varied set per column (offset so neighbours differ), duplicated so the
// vertical drift loops seamlessly.
const columns = Array.from({ length: COLS }, (_, c) => {
  const set = Array.from({ length: PER }, (_, r) => pool[(c * 3 + r) % pool.length]);
  return [...set, ...set];
});
---

<section
  class="mosaic-hero relative h-[100svh] min-h-[640px] w-full overflow-hidden bg-ink text-paper"
  data-mosaic
>
  <!-- Drifting mosaic + scroll parallax -->
  <div class="absolute inset-0" data-parallax="0.16">
    <div class="mosaic-stage">
      {
        columns.map((tiles, c) => (
          <div class:list={['mosaic-col', c % 2 === 1 && 'is-rev']} style={`--dur:${36 + c * 8}s`}>
            <div class="mosaic-track">
              {tiles.map((a) => (
                <figure class="mosaic-tile fig-grid">
                  <img
                    src={webpOf(a)}
                    alt=""
                    aria-hidden="true"
                    loading="eager"
                    decoding="async"
                    class="h-full w-full object-cover"
                  />
                </figure>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Cinematic wash -->
  <div class="mosaic-tint" aria-hidden="true"></div>
  <div class="mosaic-shade" aria-hidden="true"></div>

  <!-- Corner metadata -->
  <div class="shell absolute inset-x-0 top-0 z-10 flex items-center justify-between pt-28 md:pt-32">
    <p class="corner-label text-paper/60">{site.location.city} · {site.location.canton}</p>
    <p class="corner-label hidden text-paper/55 sm:block">Est. 2025 — CH</p>
  </div>

  <!-- Main -->
  <div class="shell relative z-10 flex h-full flex-col justify-end pb-12 md:pb-16">
    <p class="kicker !text-paper/75" data-reveal>Architecture × Commercialization</p>
    <h1
      class="mosaic-title mt-5 max-w-[16ch] font-sans text-[clamp(2.9rem,1rem+9vw,9.5rem)] font-bold leading-[0.9] tracking-[-0.04em]"
      data-split
      data-split-now
    >
      From land to the last apartment sold.
    </h1>

    <div class="mt-8 flex flex-col gap-7 md:flex-row md:items-end md:justify-between">
      <p
        class="max-w-md font-serif text-xl leading-snug text-paper/85"
        data-reveal
        style="--reveal-delay:350ms"
      >
        {site.shortPitch}
      </p>
      <div
        class="flex flex-wrap items-center gap-x-6 gap-y-4"
        data-reveal
        style="--reveal-delay:450ms"
      >
        <span class="inline-block" data-magnetic>
          <Button href="/contact/" variant="inverse">Talk about your project</Button>
        </span>
        <Button href="/method/" variant="line" class="!text-paper">See the method</Button>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div
    class="absolute bottom-5 left-1/2 z-10 hidden -translate-x-1/2 md:flex md:flex-col md:items-center md:gap-2"
    aria-hidden="true"
  >
    <span class="corner-label text-paper/45">Scroll</span>
    <span class="mosaic-scrollline"></span>
  </div>
</section>

<style>
  .mosaic-stage {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 150vmax;
    height: 150vmax;
    transform: translate(-50%, -50%) rotate(-20deg);
    display: flex;
    gap: clamp(10px, 1vw, 20px);
    will-change: transform;
  }
  .mosaic-col {
    flex: 1 1 0;
    overflow: hidden;
  }
  .mosaic-track {
    display: flex;
    flex-direction: column;
    animation: mosaic-drift var(--dur, 45s) linear infinite;
    will-change: transform;
  }
  .mosaic-col.is-rev .mosaic-track {
    animation-direction: reverse;
  }
  /* The track holds two identical sets; -50% lands exactly one set on, so the
     loop is seamless. Spacing lives on the tile (not gap) to keep both sets —
     including trailing space — pixel-identical. */
  @keyframes mosaic-drift {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }
  .mosaic-tile {
    flex: none;
    aspect-ratio: 3 / 4;
    margin-bottom: clamp(10px, 1vw, 20px);
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-graphite);
  }
  .mosaic-tile img {
    filter: saturate(0.9) contrast(1.02) brightness(0.96);
  }

  /* Unifying tint — slate over the warm renders (the architecture strand) */
  .mosaic-tint {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: linear-gradient(150deg, var(--color-blueprint), var(--color-ink));
    opacity: 0.46;
    mix-blend-mode: multiply;
  }
  /* Legibility gradient — heavy at the bottom where the headline lives */
  .mosaic-shade {
    position: absolute;
    inset: 0;
    z-index: 6;
    pointer-events: none;
    background:
      linear-gradient(
        to top,
        var(--color-ink) 2%,
        color-mix(in srgb, var(--color-ink) 38%, transparent) 40%,
        transparent 74%
      ),
      linear-gradient(to bottom, color-mix(in srgb, var(--color-ink) 55%, transparent), transparent 22%),
      radial-gradient(
        130% 100% at 78% 115%,
        color-mix(in srgb, var(--color-ink) 82%, transparent),
        transparent 56%
      );
  }

  .mosaic-scrollline {
    width: 1px;
    height: 38px;
    background: linear-gradient(to bottom, rgba(245, 242, 236, 0.5), transparent);
    animation: mosaic-drop 2.2s var(--ease-out-expo) infinite;
  }
  @keyframes mosaic-drop {
    0% {
      transform: scaleY(0);
      transform-origin: top;
    }
    40% {
      transform: scaleY(1);
      transform-origin: top;
    }
    60% {
      transform: scaleY(1);
      transform-origin: bottom;
    }
    100% {
      transform: scaleY(0);
      transform-origin: bottom;
    }
  }

  /* Accent the final word of the headline */
  .mosaic-title :global(.word-mask:last-of-type .word) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--color-clay-soft);
  }

  /* Fewer columns on smaller screens — flex:1 refills the width, so coverage
     is preserved while the DOM/paint stays light. */
  @media (max-width: 1024px) {
    .mosaic-col:nth-child(n + 5) {
      display: none;
    }
  }
  @media (max-width: 640px) {
    .mosaic-col:nth-child(n + 4) {
      display: none;
    }
    .mosaic-stage {
      transform: translate(-50%, -50%) rotate(-24deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mosaic-track,
    .mosaic-scrollline {
      animation: none;
    }
  }
</style>
