---
/**
 * FoundersHero — two principals full-bleed and edge-to-edge, each with a solid
 * white text card overlaid at the bottom, staggered (left flush to the bottom,
 * right raised). Photos and cards each take their own parallax at different
 * rates, so the cards drift against the portraits. Heads are anchored high so
 * the framing never crops them.
 */
import { getFounder } from '@data/founders';
import { site } from '@data/site';

const esad = getFounder('esad');
const dionis = getFounder('dionis');
const webp = (p: string) => p.replace(/\.jpe?g$/i, '.webp');

const cols = [
  { f: esad, photo: '0.16', tone: 'text-blueprint' },
  { f: dionis, photo: '-0.13', tone: 'text-clay' },
];

const cards = [
  {
    f: esad,
    href: '/architecture/',
    tone: 'text-blueprint',
    bar: 'bg-blueprint',
    heading: 'A design a bank can fund.',
    body: 'Feasibility, plans and permit-ready design — value engineered from the first line.',
    label: 'Architecture',
    pos: 'left-0 bottom-0',
    parallax: '0.2',
    cursor: 'Architecture',
  },
  {
    f: dionis,
    href: '/commercialization/',
    tone: 'text-clay',
    bar: 'bg-clay',
    heading: 'Sold before it’s built.',
    body: 'Pricing, dossier and off-plan pre-sale that clears the bank’s quota — through to the last lot.',
    label: 'Commercialization',
    pos: 'right-0 bottom-[26%]',
    parallax: '-0.16',
    cursor: 'Commercialization',
  },
];
---

<section
  class="founders-hero relative h-[100svh] min-h-[640px] w-full overflow-hidden bg-graphite text-paper"
>
  <h1 class="sr-only">
    ZweiFach — from land to the last apartment sold. Architecture and commercialization under one roof.
  </h1>

  <!-- Two portraits, edge to edge -->
  <div class="grid h-full grid-cols-2">
    {
      cols.map((c) => (
        <div class="relative h-full overflow-hidden">
          <div class="founders-hero__media absolute -inset-[12%]" data-parallax={c.photo}>
            <picture class="block h-full w-full">
              <source srcset={webp(c.f.portrait!)} type="image/webp" />
              <img
                src={c.f.portrait}
                alt={c.f.portraitAlt}
                loading="eager"
                decoding="async"
                class="h-full w-full object-cover"
                style="object-position:50% 6%"
              />
            </picture>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Soft top scrim for the header -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-36 bg-gradient-to-b from-graphite/65 to-transparent"
  >
  </div>

  <!-- Top meta -->
  <div class="shell absolute inset-x-0 top-0 z-20 flex items-center justify-between pt-28 md:pt-32">
    <p class="kicker !text-paper/80" data-reveal>Architecture × Commercialization</p>
    <p class="corner-label hidden text-paper/65 sm:block">{site.location.city} · {site.location.canton}</p>
  </div>

  <!-- Two white text cards, staggered, each parallaxing against its photo -->
  {
    cards.map((c) => (
      <div class:list={['absolute z-10 w-[min(86vw,30rem)]', c.pos]} data-parallax={c.parallax}>
        <a
          href={c.href}
          class="founders-card group block bg-paper p-7 text-ink md:p-9"
          data-reveal
          data-cursor
          data-cursor-label={c.cursor}
        >
          <div class="flex items-center gap-3">
            <span class:list={['h-1.5 w-1.5 rounded-full', c.bar]} />
            <span class:list={['corner-label', c.tone]}>{c.label}</span>
          </div>
          <p class="mt-4 font-sans text-[clamp(1.5rem,1rem+1.8vw,2.4rem)] font-bold leading-[1.04] tracking-[-0.02em]">
            {c.heading}
          </p>
          <p class="mt-3 max-w-sm text-sm leading-relaxed text-ink/65">{c.body}</p>
          <div class="mt-5 flex items-center justify-between">
            <span class="font-sans text-sm font-semibold">{c.f.name}</span>
            <span
              class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-ink/20 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:translate-x-1"
              aria-hidden="true"
            >
              →
            </span>
          </div>
        </a>
      </div>
    ))
  }
</section>
