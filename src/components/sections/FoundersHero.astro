---
/**
 * FoundersHero — the home opener: the two principals, full-bleed and
 * edge-to-edge (no gutter, no gap). Each portrait AND its caption take their
 * own parallax (at different rates, so text drifts against its photo), and the
 * captions sit on the outer edges + a bottom scrim so they never cover the
 * faces. object-position is anchored high so heads are never cropped.
 */
import { getFounder } from '@data/founders';
import { site } from '@data/site';
import Button from '@components/ui/Button.astro';

const esad = getFounder('esad');
const dionis = getFounder('dionis');
const webp = (p: string) => p.replace(/\.jpe?g$/i, '.webp');

const cols = [
  {
    f: esad,
    photo: '0.07',
    text: '0.03',
    tone: 'text-blueprint-soft',
    align: 'text-left',
    bottom: '24%',
    label: 'Architecture',
    lead: 'Feasibility, plans and design — a project a bank can fund.',
  },
  {
    f: dionis,
    photo: '-0.06',
    text: '-0.025',
    tone: 'text-clay-soft',
    align: 'text-right',
    bottom: '14%',
    label: 'Commercialization',
    lead: 'Pricing, dossier and off-plan pre-sale — sold to the last lot.',
  },
];
---

<section
  class="founders-hero relative h-[100svh] min-h-[620px] w-full overflow-hidden bg-graphite text-paper"
>
  <!-- Two portraits, edge to edge -->
  <div class="grid h-full grid-cols-2">
    {
      cols.map((c) => (
        <div class="relative h-full overflow-hidden">
          <div class="founders-hero__media absolute -inset-[4%]" data-parallax={c.photo}>
            <picture class="block h-full w-full">
              <source srcset={webp(c.f.portrait!)} type="image/webp" />
              <img
                src={c.f.portrait}
                alt={c.f.portraitAlt}
                loading="eager"
                decoding="async"
                class="h-full w-full object-cover"
                style="object-position:50% 6%"
              />
            </picture>
          </div>

          {/* Per-founder caption — parallaxes against its own photo */}
          <div class="absolute inset-x-0 z-10" style={`bottom:${c.bottom}`} data-parallax={c.text}>
            <div class:list={['px-[var(--gutter)]', c.align]} data-reveal>
              <p class="font-sans text-lg font-semibold md:text-xl">{c.f.name}</p>
              <p class:list={['corner-label mt-1', c.tone]}>{c.label}</p>
              <p
                class:list={[
                  'mt-3 max-w-xs text-sm leading-relaxed text-paper/75',
                  c.align === 'text-right' && 'ml-auto',
                ]}
              >
                {c.lead}
              </p>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Scrims -->
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-graphite via-graphite/35 to-transparent"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-graphite/65 to-transparent"
  >
  </div>

  <!-- Top meta -->
  <div class="shell absolute inset-x-0 top-0 z-20 flex items-center justify-between pt-28 md:pt-32">
    <p class="kicker !text-paper/75" data-reveal>Architecture × Commercialization</p>
    <p class="corner-label hidden text-paper/55 sm:block">{site.location.city} · {site.location.canton}</p>
  </div>

  <!-- Bottom band: the line + CTAs -->
  <div class="shell absolute inset-x-0 bottom-0 z-20 pb-9 md:pb-12">
    <div
      class="flex flex-col gap-5 border-t border-paper/15 pt-6 md:flex-row md:items-end md:justify-between"
    >
      <h1
        class="max-w-[15ch] font-serif text-[clamp(1.9rem,1rem+3vw,4rem)] leading-[1.02]"
        data-split
        data-split-now
      >
        From land to the last apartment sold.
      </h1>
      <div
        class="flex flex-wrap items-center gap-x-6 gap-y-3"
        data-reveal
        style="--reveal-delay:200ms"
      >
        <span class="inline-block" data-magnetic>
          <Button href="/contact/" variant="inverse">Talk about your project</Button>
        </span>
        <Button href="/method/" variant="line" class="!text-paper">See the method</Button>
      </div>
    </div>
  </div>
</section>
