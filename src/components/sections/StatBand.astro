---
import { stats } from '@data/stats';

interface Props {
  tone?: 'paper' | 'graphite';
  class?: string;
}
const { tone = 'paper', class: className = '' } = Astro.props;
const dark = tone === 'graphite';
---

<dl class:list={['grid grid-cols-2 gap-x-6 gap-y-9 md:grid-cols-4 md:gap-x-8', className]}>
  {
    stats.map((s, i) => (
      <div
        data-reveal
        style={`--reveal-delay:${i * 80}ms`}
        class:list={['border-t pt-4', dark ? 'border-paper/25' : 'border-ink/20']}
      >
        <dt class="font-sans text-[2.6rem] font-semibold leading-none tracking-tight md:text-5xl">
          {s.value}
        </dt>
        <dd class:list={['mt-3 text-sm leading-snug', dark ? 'text-paper/65' : 'text-ink/65']}>
          {s.label}
        </dd>
        {s.note && (
          <dd class:list={['mt-1.5 font-mono text-[0.65rem] leading-snug', dark ? 'text-paper/40' : 'text-taupe']}>
            {s.note}
          </dd>
        )}
      </div>
    ))
  }
</dl>
