---
import { partners } from '@data/partners';
---

<div class="grid gap-6 md:grid-cols-2">
  {
    partners.map((p, i) => (
      <div
        data-reveal
        style={`--reveal-delay:${i * 90}ms`}
        class="rounded-2xl border border-ink/10 bg-paper p-7 transition-colors hover:border-ink/25"
      >
        <div class="flex items-start justify-between gap-4">
          <h3 class="font-sans text-xl font-semibold">{p.name}</h3>
          <span class="mt-1 shrink-0 font-mono text-[0.6rem] uppercase tracking-wider text-taupe">
            {p.kind}
          </span>
        </div>
        <p class="mt-1 font-mono text-xs text-clay">{p.role}</p>
        <p class="mt-3 text-sm leading-relaxed text-ink/65">{p.description}</p>
        {p.url && (
          <a
            href={p.url}
            target="_blank"
            rel="noopener"
            class="link-underline mt-4 inline-block text-sm font-medium"
          >
            Visit {p.name} →
          </a>
        )}
      </div>
    ))
  }
</div>
