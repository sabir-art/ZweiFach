---
import Button from '@components/ui/Button.astro';

interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = 'Let’s talk about your project.',
  text = 'Whether you have land, a project to structure, or a building to bring to market — the chain starts with a conversation.',
} = Astro.props;

const intents = [
  { label: 'I have land', href: '/contact/?intent=land' },
  { label: 'I have a project to structure', href: '/contact/?intent=structure' },
  { label: 'I’m preparing to go to market', href: '/contact/?intent=market' },
];
---

<section class="relative overflow-hidden bg-graphite text-paper">
  <div class="shell py-24 md:py-36">
    <div class="h-[2px] w-16 bg-gradient-to-r from-blueprint to-clay" data-reveal aria-hidden="true"></div>
    <h2
      class="mt-8 max-w-5xl display text-[clamp(2.6rem,1rem+6.4vw,7rem)]"
      data-split
    >
      {heading}
    </h2>
    <p class="mt-8 max-w-xl text-lg text-paper/70" data-reveal>{text}</p>

    <div class="mt-9 flex flex-wrap gap-3" data-reveal>
      {
        intents.map((i) => (
          <a
            href={i.href}
            class="rounded-full border border-paper/25 px-4 py-2 text-sm text-paper/85 transition-colors duration-300 hover:border-paper hover:bg-paper hover:text-ink"
          >
            {i.label}
          </a>
        ))
      }
    </div>

    <div class="mt-11" data-reveal>
      <span class="inline-block" data-magnetic>
        <Button href="/contact/" variant="inverse">Talk about your project</Button>
      </span>
    </div>
  </div>
</section>
