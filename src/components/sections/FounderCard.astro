---
import type { Founder } from '@data/founders';
import Figure from '@components/ui/Figure.astro';

interface Props {
  founder: Founder;
  detailed?: boolean;
}
const { founder: f, detailed = false } = Astro.props;
const strandText = f.strand === 'blueprint' ? 'text-blueprint' : 'text-clay';
const strandBg = f.strand === 'blueprint' ? 'bg-blueprint' : 'bg-clay';
---

<div data-reveal>
  <Figure src={f.portrait} alt={f.portraitAlt} aspect="4 / 5" class="rounded-xl">
    {
      !f.portrait && (
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 text-center">
          <span class:list={['h-12 w-[3px] rounded-sm', strandBg]} />
          <span class="font-mono text-[0.6rem] uppercase tracking-wider text-taupe">
            Portrait — photo to be added
          </span>
        </div>
      )
    }
  </Figure>

  <div class="mt-5 flex items-center gap-2.5">
    <span class:list={['h-3 w-[3px] rounded-sm', strandBg]} aria-hidden="true"></span>
    <p class:list={['font-mono text-[0.68rem] uppercase tracking-wider', strandText]}>
      {f.discipline}
    </p>
  </div>
  <h3 class="mt-2 font-serif text-3xl">{f.name}</h3>
  <p class="mt-1 text-sm text-ink/60">{f.role}</p>
  <p class="mt-1 font-mono text-xs text-taupe">{f.credential}</p>
  <p class="mt-4 max-w-md text-lg leading-snug text-ink/85">{f.lead}</p>

  {!detailed && <p class="mt-3 max-w-md text-sm leading-relaxed text-ink/60">{f.bio}</p>}

  {
    detailed && (
      <div class="mt-6">
        <p class="kicker kicker--bare">Delivers</p>
        <ul class="mt-3 space-y-2 text-sm text-ink/75">
          {f.does.map((d) => (
            <li class="flex gap-2.5">
              <span class={strandText}>—</span>
              {d}
            </li>
          ))}
        </ul>
        {f.doesNot && (
          <div class="mt-5 rounded-xl border border-ink/10 bg-paper-2 p-5">
            <p class="kicker kicker--bare">Scope, stated honestly</p>
            <ul class="mt-2 space-y-1.5 text-sm text-ink/60">
              {f.doesNot.map((d) => (
                <li class="flex gap-2.5">
                  <span class="text-taupe">·</span>
                  {d}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )
  }
</div>
