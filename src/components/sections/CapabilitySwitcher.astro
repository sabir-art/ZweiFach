---
/**
 * CapabilitySwitcher — ZweiFach's take on the Springs "Wellness" tab slider.
 * Four capabilities spanning the chain; clicking (or focusing) one wipes its
 * image in with a clip-path and fades its copy in. First item is server-marked
 * active, so it reads fully even with no JS. Logic in initSwitcher (ui.ts).
 */
import { assets, assetSrc } from '@data/assets';

const webpOf = (a: { local: string }) => {
  const u = assetSrc(a as never);
  return u.startsWith('/') && /\.jpe?g$/i.test(u) ? u.replace(/\.jpe?g$/i, '.webp') : u;
};

const caps = [
  {
    n: '01',
    title: 'Feasibility',
    owner: 'Esad · Architecture',
    strand: 'blueprint' as const,
    asset: assets.caseHoehenweg,
    desc: 'What can responsibly and profitably be built on a site — tested against zoning, density, cost and risk before anyone commits a franc.',
    points: ['Machbarkeitsstudie', 'Density & yield', 'Risk read'],
  },
  {
    n: '02',
    title: 'Design & Plans',
    owner: 'Esad · Architecture',
    strand: 'blueprint' as const,
    asset: assets.archModel,
    desc: 'The parti, the massing, the plans and sections — an architectural idea made concrete, permit-ready, and drawn from the start to be financeable.',
    points: ['Massing & daylight', 'Permit-ready drawings', 'Engineer coordination'],
  },
  {
    n: '03',
    title: 'Pricing & Dossier',
    owner: 'Dionis · Commercialization',
    strand: 'clay' as const,
    asset: assets.interiorKitchen,
    desc: 'A price strategy the project can actually achieve, and the dossier — lot schedule, numbers, story — that makes a serious buyer and a bank say yes.',
    points: ['Market positioning', 'Lot schedule', 'Sales dossier'],
  },
  {
    n: '04',
    title: 'Off-plan Pre-sale',
    owner: 'Dionis · Commercialization',
    strand: 'clay' as const,
    asset: assets.caseAarefeld,
    desc: 'Reservations on plans, driven hard enough to clear the bank’s quota and unlock construction credit — then carried through to the final unit.',
    points: ['Clear the quota', 'Pipeline management', 'Sell-through'],
  },
];

const tone = (s: string) => (s === 'clay' ? 'text-clay' : 'text-blueprint');
const dot = (s: string) => (s === 'clay' ? 'bg-clay' : 'bg-blueprint');
---

<div class="grid gap-x-12 gap-y-10 lg:grid-cols-12" data-switcher>
  <!-- Tabs -->
  <div class="lg:col-span-5">
    <ul role="tablist" aria-label="Capabilities">
      {
        caps.map((c, i) => (
          <li>
            <button
              type="button"
              role="tab"
              data-switch-tab
              id={`cap-tab-${i}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`cap-panel-${i}`}
              class:list={[
                'switch-tab group flex w-full items-center gap-4 border-t border-ink/15 py-5 text-left',
                i === 0 && 'is-active',
              ]}
            >
              <span class="font-mono text-xs text-taupe">{c.n}</span>
              <span class:list={['h-1.5 w-1.5 shrink-0 rounded-full', dot(c.strand)]} />
              <span class="switch-tab-label font-sans text-2xl font-semibold tracking-tight md:text-[1.75rem]">
                {c.title}
              </span>
              <span class="switch-tab-arrow ml-auto translate-x-[-6px] text-lg opacity-0" aria-hidden="true">
                →
              </span>
            </button>
          </li>
        ))
      }
    </ul>
    <div class="mt-3 h-px w-full overflow-hidden bg-ink/12">
      <span
        class="block h-full origin-left bg-ink transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"
        style="transform:scaleX(0.25)"
        data-switch-bar></span>
    </div>
  </div>

  <!-- Media + panels -->
  <div class="lg:col-span-7">
    <div class="relative aspect-[4/3] overflow-hidden rounded-2xl">
      {
        caps.map((c, i) => (
          <figure
            data-switch-media
            class:list={['switch-media fig-grid absolute inset-0', i === 0 && 'is-active']}
          >
            <img
              src={webpOf(c.asset)}
              alt={c.asset.alt}
              width={c.asset.width}
              height={c.asset.height}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              class="h-full w-full object-cover"
            />
          </figure>
        ))
      }
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/35 to-transparent"></div>
    </div>

    <div class="relative mt-7 min-h-[160px] sm:min-h-[140px]">
      {
        caps.map((c, i) => (
          <div
            data-switch-panel
            role="tabpanel"
            id={`cap-panel-${i}`}
            aria-labelledby={`cap-tab-${i}`}
            class:list={['switch-panel', i === 0 && 'is-active']}
          >
            <p class:list={['font-mono text-[0.7rem] uppercase tracking-[0.18em]', tone(c.strand)]}>
              {c.owner}
            </p>
            <p class="mt-3 max-w-lg text-lg leading-relaxed text-ink/75">{c.desc}</p>
            <ul class="mt-5 flex flex-wrap gap-x-6 gap-y-2">
              {c.points.map((p) => (
                <li class="flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-taupe">
                  <span class:list={['h-1 w-1 rounded-full', dot(c.strand)]} />
                  {p}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .switch-tab {
    opacity: 0.45;
    transition: opacity 0.4s var(--ease-out-expo);
    cursor: pointer;
  }
  .switch-tab.is-active {
    opacity: 1;
  }
  .switch-tab-arrow {
    transition:
      opacity 0.4s var(--ease-out-expo),
      transform 0.4s var(--ease-out-expo);
  }
  .switch-tab.is-active .switch-tab-arrow,
  .switch-tab:hover .switch-tab-arrow {
    opacity: 0.6;
    transform: translateX(0);
  }

  .switch-media {
    clip-path: polygon(0% 0%, 0% 0%, 0% 100%, 0% 100%);
    opacity: 0;
    transition:
      clip-path 0.85s var(--ease-out-expo),
      opacity 0.5s var(--ease-out-expo);
  }
  .switch-media.is-active {
    clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    opacity: 1;
  }

  .switch-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition:
      opacity 0.5s var(--ease-out-expo),
      transform 0.5s var(--ease-out-expo);
  }
  .switch-panel.is-active {
    position: relative;
    opacity: 1;
    visibility: visible;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .switch-media,
    .switch-panel,
    .switch-tab,
    .switch-tab-arrow {
      transition: none;
    }
  }
</style>
