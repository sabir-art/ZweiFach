---
/**
 * LocationSection — sticky video storytelling (Springs "Place"/"Map").
 * A full-bleed Seedance clip (golden-hour → dusk over the development) pins for
 * the section while the caption and region facts reveal. Falls back to the
 * generated still poster until the clip is wired in media.ts.
 */
import { media } from '@data/media';
import { site } from '@data/site';

const facts = [
  { k: 'Base', v: `${site.location.city}, ${site.location.canton}` },
  { k: 'Working area', v: 'Swiss Mittelland & NW' },
  { k: 'Focus', v: 'Residential development' },
];
---

<section class="relative bg-ink text-paper">
  <div class="relative h-[150vh]">
    <div class="sticky top-0 z-[1] h-screen overflow-hidden">
      {
        media.locationVideo ? (
          <video
            class="loc-media absolute inset-0 h-full w-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster={media.locationPoster}
          >
            <source src={media.locationVideo} type="video/mp4" />
          </video>
        ) : (
          <img
            class="loc-media absolute inset-0 h-full w-full object-cover"
            src={media.locationPoster}
            alt=""
            aria-hidden="true"
            decoding="async"
          />
        )
      }

      <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-ink/15"></div>
      <div
        class="absolute inset-0 bg-gradient-to-br from-blueprint/45 to-transparent mix-blend-multiply"
      >
      </div>

      <div class="shell relative z-10 flex h-full flex-col justify-end pb-16 md:pb-24">
        <div class="flex items-center justify-between">
          <p class="kicker !text-paper/70" data-reveal>Where we work</p>
          <span class="corner-label text-paper/40" data-reveal>(05)</span>
        </div>
        <h2
          class="mt-6 max-w-3xl font-serif text-[clamp(2rem,1rem+4vw,5rem)] leading-[1.04]"
          data-split
        >
          Rooted in the Swiss Mittelland.
        </h2>
        <p
          class="mt-6 max-w-md text-lg leading-relaxed text-paper/75"
          data-reveal
          data-reveal-dir="right"
          style="--reveal-delay:200ms"
        >
          We develop where we live — close to the sites, the authorities and the
          buyers, across Solothurn and the wider Mittelland.
        </p>
        <dl
          class="mt-10 grid max-w-2xl grid-cols-2 gap-x-10 gap-y-6 border-t border-paper/15 pt-8 sm:grid-cols-3"
          data-reveal
          data-reveal-dir="right"
          style="--reveal-delay:300ms"
        >
          {
            facts.map((f) => (
              <div>
                <dt class="corner-label text-paper/45">{f.k}</dt>
                <dd class="mt-1.5 font-sans text-lg">{f.v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>

<style>
  .loc-media {
    animation: loc-kenburns 30s ease-in-out infinite alternate;
    transform-origin: 55% 50%;
  }
  @keyframes loc-kenburns {
    from {
      transform: scale(1.02);
    }
    to {
      transform: scale(1.12);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .loc-media {
      animation: none;
    }
  }
</style>
